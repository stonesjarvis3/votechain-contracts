{
  "apiVersion": "v1",
  "kind": "ConfigMap",
  "metadata": {
    "name": "votechain-contracts-dashboard",
    "namespace": "monitoring"
  },
  "data": {
    "dashboard.json": {
      "dashboard": {
        "title": "VoteChain Contracts - Health & Metrics",
        "uid": "votechain-contracts",
        "timezone": "browser",
        "panels": [
          {
            "id": 1,
            "title": "Contract Deployment Status",
            "type": "stat",
            "gridPos": {
              "h": 8,
              "w": 12,
              "x": 0,
              "y": 0
            },
            "targets": [
              {
                "expr": "contract_deployment_status{instance=~\"$instance\"}",
                "legendFormat": "{{ contract_name }}"
              }
            ],
            "thresholds": "0,1",
            "colorMode": "background",
            "mappings": [
              {
                "type": "value",
                "options": {
                  "1": {
                    "text": "Active",
                    "color": "green"
                  },
                  "0": {
                    "text": "Inactive",
                    "color": "red"
                  }
                }
              }
            ]
          },
          {
            "id": 2,
            "title": "Call Latency (P99)",
            "type": "graph",
            "gridPos": {
              "h": 8,
              "w": 12,
              "x": 12,
              "y": 0
            },
            "targets": [
              {
                "expr": "histogram_quantile(0.99, rate(contract_call_duration_seconds_bucket[5m]))",
                "legendFormat": "{{ method }}"
              }
            ],
            "yaxes": [
              {
                "label": "Duration (seconds)",
                "format": "s"
              }
            ]
          },
          {
            "id": 3,
            "title": "Error Rate",
            "type": "graph",
            "gridPos": {
              "h": 8,
              "w": 12,
              "x": 0,
              "y": 8
            },
            "targets": [
              {
                "expr": "rate(contract_calls_total{status=\"error\"}[5m])",
                "legendFormat": "{{ contract_name }}"
              }
            ],
            "yaxes": [
              {
                "label": "Errors/sec",
                "format": "short"
              }
            ],
            "alert": {
              "name": "High Error Rate",
              "conditions": [
                {
                  "evaluator": {
                    "params": [0.05],
                    "type": "gt"
                  }
                }
              ],
              "frequency": "5m",
              "handler": 1,
              "message": "Error rate above 5%"
            }
          },
          {
            "id": 4,
            "title": "Total Transactions",
            "type": "stat",
            "gridPos": {
              "h": 8,
              "w": 6,
              "x": 12,
              "y": 8
            },
            "targets": [
              {
                "expr": "contract_calls_total{instance=~\"$instance\"}"
              }
            ]
          },
          {
            "id": 5,
            "title": "Active Governance Proposals",
            "type": "stat",
            "gridPos": {
              "h": 8,
              "w": 6,
              "x": 18,
              "y": 8
            },
            "targets": [
              {
                "expr": "contract_governance_active_proposals{instance=~\"$instance\"}"
              }
            ]
          },
          {
            "id": 6,
            "title": "Token Supply",
            "type": "gauge",
            "gridPos": {
              "h": 8,
              "w": 12,
              "x": 0,
              "y": 16
            },
            "targets": [
              {
                "expr": "contract_token_total_supply{instance=~\"$instance\"}"
              }
            ],
            "thresholds": "0,1000000"
          },
          {
            "id": 7,
            "title": "Build Artifacts",
            "type": "table",
            "gridPos": {
              "h": 8,
              "w": 12,
              "x": 12,
              "y": 16
            },
            "targets": [
              {
                "expr": "build_info{instance=~\"$instance\"}"
              }
            ],
            "transformations": [
              {
                "id": "organize",
                "options": {
                  "excludeByName": {}
                }
              }
            ]
          }
        ],
        "templating": {
          "list": [
            {
              "name": "instance",
              "type": "query",
              "query": "label_values(up, instance)",
              "multi": true,
              "includeAll": true
            }
          ]
        },
        "refresh": "30s",
        "time": {
          "from": "now-1h",
          "to": "now"
        }
      }
    }
  }
}
