# Integration environment configuration
# Copy this to .env.integration and fill in values.
# This file is safe to commit. .env.integration is gitignored.

# Stellar local network (used by docker-compose.integration.yml)
NETWORK=local
STELLAR_RPC_URL=http://localhost:8000/soroban/rpc
STELLAR_NETWORK_PASSPHRASE=Standalone Network ; February 2017

# A funded local account secret (generated by stellar-quickstart, safe for local use only)
# Replace with output of: stellar keys generate --network local integration-deployer
STELLAR_SECRET_KEY=SCZANGBA5YELYSLJDZWSLLH3RX3PTQQO7GIJQMDNLH4YIQKUVHBDMPU

# Redis connection
REDIS_URL=redis://localhost:6379

# Populated by scripts/provision-integration-env.sh after contract deployment
VOTECHAIN_GOVERNANCE_CONTRACT_ID=
VOTECHAIN_TOKEN_CONTRACT_ID=
